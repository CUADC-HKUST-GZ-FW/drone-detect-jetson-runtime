{
  "policy_id": "demo-degraded-video",
  "target_node": "jetson-a",
  "interface": "eth0",
  "mode": "dry-run",
  "backend": "simple",
  "root_rate_mbit": 10,
  "safety": {
    "dry_run": true,
    "auto_rollback_seconds": 45,
    "require_confirm": true,
    "allow_ssh_interface": false
  },
  "default": {
    "bandwidth_mbit": 4,
    "priority": 7
  },
  "rules": [
    {
      "name": "degraded-video-flow",
      "match": {
        "dst_ip": "JETSON_B_IP",
        "dst_port": 5000,
        "protocol": "udp"
      },
      "bandwidth_mbit": 2,
      "delay_ms": 80,
      "loss_percent": 2.0,
      "priority": 2
    }
  ]
}
